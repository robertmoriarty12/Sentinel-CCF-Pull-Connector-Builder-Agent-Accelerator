[
  {
    "type": "Microsoft.SecurityInsights/dataConnectors",
    "apiVersion": "2023-02-01-preview",
    "name": "NetworkLogAPINetworkLogsConnector",
    "location": "{{location}}",
    "kind": "RestApiPoller",
    "properties": {
      "connectorDefinitionName": "NetworkLogAPIConnectorDef",
      "dataType": "NetworkLogAPINetworkLogs_CL",
      "dcrConfig": {
        "streamName": "Custom-NetworkLogAPINetworkLogs_CL",
        "dataCollectionEndpoint": "{{dataCollectionEndpoint}}",
        "dataCollectionRuleImmutableId": "{{dataCollectionRuleImmutableId}}"
      },
      "auth": {
        "type": "APIKey",
        "ApiKey": "{{apiKey}}",
        "ApiKeyName": "X-API-Key",
        "ApiKeyIdentifier": ""
      },
      "request": {
        "apiEndpoint": "{{BaseUrl}}/api/GetNetworkLogs",
        "httpMethod": "GET",
        "queryTimeFormat": "yyyy-MM-ddTHH:mm:ssZ",
        "rateLimitQPS": 10,
        "queryWindowInMin": 5,
        "retryCount": 3,
        "timeoutInSeconds": 60,
        "StartTimeAttributeName": "since",
        "queryParameters": {
          "pageSize": "100"
        }
      },
      "paging": {
        "pagingType": "NextPageUrl",
        "nextPageUrl": "$.metadata.nextLink",
        "hasNextFlagJsonPath": "$.metadata.hasNextPage",
        "pageSize": 100,
        "pageSizeParameterName": "pageSize"
      },
      "response": {
        "eventsJsonPaths": ["$.data"],
        "format": "json",
        "successStatusJsonPath": "$.status",
        "successStatusValue": "success"
      }
    }
  }
]
